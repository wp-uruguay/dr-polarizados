# Variables de entorno requeridas para Dr Polarizados
# Copiar este archivo como .env.local y completar los valores

# Resend — servicio de email para formularios de contacto
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dirección FROM para los emails enviados (debe estar verificada en Resend)
RESEND_FROM_EMAIL=formulario@drpolarizados.com
